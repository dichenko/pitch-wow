APP_ENV=production
ADMIN_BASE_URL=https://admin.pitchwow.example.com

POSTGRES_DB=pitchwow
POSTGRES_USER=pitchwow
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+psycopg://pitchwow:change_me@postgres:5432/pitchwow

REDIS_URL=redis://redis:6379/0

# Bot mode: polling (default, no public URL needed) or webhook (requires public HTTPS URL)
TELEGRAM_MODE=polling
TELEGRAM_BOT_TOKEN=replace_with_new_rotated_token
TELEGRAM_WEBHOOK_SECRET=replace_with_random_secret
# Full public URL where Telegram sends updates (only used when TELEGRAM_MODE=webhook)
TELEGRAM_WEBHOOK_URL=https://pitchwow.example.com/telegram/webhook
# Port the bot listens on in webhook mode (Caddy must proxy to this port)
TELEGRAM_WEBHOOK_PORT=8443

ANTHROPIC_API_KEY=replace_me
ANTHROPIC_PRIMARY_MODEL=claude-sonnet-4-6
ANTHROPIC_CLASSIFIER_MODEL=claude-haiku-4-5

# ── STT: OpenAI (Russian/English — primary) ────────────────────────────────
OPENAI_API_KEY=sk-proj-replace_me
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_STT_MODEL=gpt-4o-transcribe

# ── STT: Muxlisa (Uzbek — fallback) ───────────────────────────────────────────
MUXLISA_API_KEY=replace_me
MUXLISA_BASE_URL=https://service.muxlisa.uz
MUXLISA_STT_TIMEOUT_MS=60000
MUXLISA_TTS_TIMEOUT_MS=60000
MUXLISA_MAX_AUDIO_SIZE_MB=5
MUXLISA_MAX_AUDIO_DURATION_SEC=60
MUXLISA_TTS_MAX_CHARS=1512
MUXLISA_TTS_SPEAKER=0

# ── STT fallback behaviour ──────────────────────────────────────────────────
# If OpenAI returns confidence below this threshold, retry with Muxlisa
STT_FALLBACK_CONFIDENCE_THRESHOLD=0.7
# Max retries per provider before giving up
STT_MAX_RETRIES=2

YANDEX_FOLDER_ID=replace_me
YANDEX_API_KEY=replace_me
YANDEX_TTS_VOICE=marina
YANDEX_TTS_ROLE=friendly
YANDEX_TTS_SPEED=1.05
YANDEX_TTS_FORMAT=oggopus

LANGSMITH_TRACING=true
LANGSMITH_API_KEY=replace_me
LANGSMITH_PROJECT=pitchwow-prod

# ── Admin panel auth (via Telegram bot /admin command) ───────────────────────
# Comma-separated Telegram user IDs allowed to access the admin panel
ADMIN_TG_IDS=19422781,45689616,183866240
# Secret used to sign temporary login tokens and session cookies (generate a long random string)
ADMIN_SESSION_SECRET=ikhgkhbIUYGu6576f_replace_with_random_secret
# How long a session cookie stays valid (in hours)
ADMIN_SESSION_MAX_AGE_HOURS=3

SENTRY_DSN=
LOG_LEVEL=INFO
